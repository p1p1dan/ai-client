# Apple Code Signing & Notarization
# Copy this file to .env.local and fill in your values

# Your Apple ID email
APPLE_ID=your-apple-id@example.com

# App-Specific Password (generate at https://appleid.apple.com)
APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Team ID (find at https://developer.apple.com/account -> Membership)
APPLE_TEAM_ID=XXXXXXXXXX

# Sidecar onboarding service URL (injected at build time as __ONBOARDING_SERVICE_URL__).
# For local dev against a test server (e.g. SSH-tunneled VPS test container), point at it here.
ONBOARDING_SERVICE_URL=https://onboarding-jyw.pipidan.qzz.io
